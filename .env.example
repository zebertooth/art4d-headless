# WordPress REST API base (no trailing slash)
WORDPRESS_API_URL=https://art4d.com/wp-json

# ISR revalidation in seconds
REVALIDATE_SECONDS=60

# Secret for POST /api/revalidate (WordPress publish webhook)
REVALIDATE_SECRET=

# Public site URL (for metadata)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Set to "true" on production cutover (keeps demo out of Google until then)
NEXT_PUBLIC_ALLOW_INDEXING=false

# Phase 2 — CloudFront image CDN (add when ready)
# CLOUDFRONT_DOMAIN=d1234abcd.cloudfront.net
